{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug TUI (Launch)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/target/debug/vellum-tui",
            "args": [],
            "cwd": "${workspaceFolder}",
            "terminal": "integrated"
        },
        {
            "name": "Attach to vellum-tui",
            "type": "lldb",
            "request": "attach",
            "pid": "${command:pickMyProcess}",
            "stopOnEntry": false
        }
    ],
    "inputs": [
        {
            "id": "pickVellumProcess",
            "type": "command",
            "command": "lldb.pickMyProcess",
            "args": {
                "filter": "vellum-tui"
            }
        }
    ]
}